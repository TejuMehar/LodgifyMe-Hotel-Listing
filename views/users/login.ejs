<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center align-items-center mt-5" style="min-height: 80vh;">
  <div class="col-md-6 col-lg-5 mt-5">
    <div class="card shadow-lg border-0 rounded-4 animate__animated animate__fadeIn">
      <div class="card-body p-5">
        <h2 class="mb-4 text-center fw-bold text-gradient">
          <i class="bi bi-box-arrow-in-right me-2 text-primary"></i>Login to LodgifyMe
        </h2>
        
        <form action="/login" method="post" class="needs-validation" novalidate>
          <!-- Email -->
          <div class="mb-3">
            <label for="username" class="form-label fw-semibold">Username:</label>
            <input type="username" id="username" name="username" class="form-control rounded-3 shadow-sm" required>
            <div class="valid-feedback">Looks good!</div>
          </div>

          <!-- Password -->
          <div class="mb-4 position-relative">
            <label for="password" class="form-label fw-semibold">Password:</label>
            <input type="password" id="password" name="password"
                   class="form-control rounded-3 shadow-sm pe-5" required>

            <button type="button"
              class="btn btn-sm position-absolute top-50 end-0 translate-middle-y me-2"
              onclick="togglePassword()" tabindex="-1"
              style="z-index: 2; text-decoration: none;">
              <span id="toggleIcon"><i class="bi bi-eye-slash fs-5 text-secondary"></i></span>
            </button>

            <div class="valid-feedback">Looks good!</div>
          </div>

          <!-- Submit -->
          <div class="d-grid">
            <button class="btn btn-gradient fw-bold py-2 rounded-pill" type="submit">
              <i class="bi bi-box-arrow-in-right me-1"></i>Login
            </button>
          </div>
        </form>

        <!-- Register Redirect -->
        <div class="text-center mt-3">
          <small>Don't have an account? <a href="/signup" class="text-gradient fw-semibold">Sign Up</a></small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Gradient + Button Styling -->
<style>
  .text-gradient {
    background: linear-gradient(90deg, #ff8a00 0%, #e52e71 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .btn-gradient {
    background: linear-gradient(90deg, #ff8a00 0%, #e52e71 100%);
    color: #fff;
    border: none;
    transition: box-shadow 0.2s;
  }
  .btn-gradient:hover {
    box-shadow: 0 4px 20px rgba(229,46,113,0.2), 0 2px 4px rgba(255,138,0,0.15);
    color: #fff;
  }
</style>

<!-- Password Toggle Script -->
<script>
  function togglePassword() {
    const passwordInput = document.getElementById("password");
    const toggleIcon = document.getElementById("toggleIcon").firstElementChild;
    const isText = passwordInput.type === "text";

    passwordInput.type = isText ? "password" : "text";
    toggleIcon.className = isText ? "bi bi-eye-slash fs-5 text-secondary" : "bi bi-eye fs-5 text-secondary";
  }
</script>
